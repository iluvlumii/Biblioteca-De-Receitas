CREATE TABLE registro_projeto (
    -- Identificação (Chave Primária)
    codigo INT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    descricao TEXT,
    
    -- Performance
    quantidade INT,
    valor DECIMAL(10, 2),
    indicador VARCHAR(50),
    
    -- Temporalidade
    data DATE NOT NULL,
    horario TIME NOT NULL
);